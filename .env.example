# Provider used for embeddings AND the chat LLM: "openai" (default) or "google".
# Must be the same for ingestion and search.
PROVIDER='openai'

# --- OpenAI ---
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL='text-embedding-3-small'
OPENAI_LLM_MODEL='gpt-5-nano'

# --- Google (Gemini) ---
GOOGLE_API_KEY=
GOOGLE_EMBEDDING_MODEL='models/gemini-embedding-001'
GOOGLE_LLM_MODEL='gemini-2.5-flash-lite'

# --- PostgreSQL + pgVector ---
# Use the psycopg (v3) driver, as required by langchain-postgres.
DATABASE_URL='postgresql+psycopg://postgres:postgres@localhost:5432/rag'
PG_VECTOR_COLLECTION_NAME='pdf_documents'

# --- PDF to ingest ---
PDF_PATH='./document.pdf'

# --- Optional ---
# Max distance for a chunk to count as relevant (lower = stricter). Leave empty
# to disable: by default the 10 nearest chunks are always sent to the LLM and
# the grounding is enforced by the prompt.
SIMILARITY_THRESHOLD=
